# Copy this to .env and fill in your values
# See README.md for step-by-step instructions on getting each key

RAPIDAPI_KEY=your_rapidapi_key_here

# ── LLM keys (auto-rotation: when one hits daily limit, next is used automatically) ──
# Priority: Groq → Ollama → DeepSeek → Mistral → OpenRouter → Gemini

GROQ_API_KEY=your_groq_api_key_here   # Free 100K/day  — console.groq.com
GROQ_API_KEY_2=                       # 2nd Groq key (another free account)
GROQ_API_KEY_3=                       # 3rd Groq key

# LOCAL model via Ollama — completely free, no internet, no daily limits
# Install: https://ollama.com  then run: ollama pull llama3.1:8b
# Recommended models: llama3.1:8b (4GB) or qwen2.5:7b (4GB)
OLLAMA_MODEL=

# Works in India — free credits on signup
# Get key: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=

# Works in India — free credits on signup
# Get key: https://console.mistral.ai → API Keys
MISTRAL_API_KEY=

# Works in India — FREE models (no credits needed, just sign up)
# Get key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# May need VPN in India — 1M tokens/day free
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gmail credentials
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
DIGEST_RECIPIENT=your.email@gmail.com
