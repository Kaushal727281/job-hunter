# Copy this to .env and fill in your values
# See README.md for step-by-step instructions on getting each key

RAPIDAPI_KEY=your_rapidapi_key_here

# ── LLM keys (auto-rotation: when one hits daily limit, next is used automatically) ──
GROQ_API_KEY=your_groq_api_key_here     # Free: 100K tokens/day  — console.groq.com
GROQ_API_KEY_2=                         # Optional 2nd Groq key (different account)
GROQ_API_KEY_3=                         # Optional 3rd Groq key

# DeepSeek fallback — works in India, free credits on signup
# Get key: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=

# Gemini fallback — 1M tokens/day free (may need VPN in India)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gmail credentials
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
DIGEST_RECIPIENT=your.email@gmail.com
